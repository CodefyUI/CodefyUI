{
  "name": "I1-3 文字與 embedding — 完整答案圖",
  "description": "對應教材 I1-3。輸入兩句話，各自用 Edu-SentenceEmbedding 壓成一條有語意的 (d,) 向量，再用 CosineSimilarity 量兩者的餘弦相似度、Print 出數字。意思接近的兩句話數字會比較大（多語言模型下還能跨語言）。",
  "nodes": [
    { "id": "start",  "type": "Start",                 "position": { "x": -360, "y": 120 }, "data": { "params": {} } },

    { "id": "text_a", "type": "TextInput",             "position": { "x": -120, "y": 20 },  "data": { "params": { "value": "我喜歡貓" } } },
    { "id": "emb_a",  "type": "Edu-SentenceEmbedding", "position": { "x": 160,  "y": 20 },  "data": { "params": { "model": "multilingual" } } },

    { "id": "text_b", "type": "TextInput",             "position": { "x": -120, "y": 220 }, "data": { "params": { "value": "我愛貓咪" } } },
    { "id": "emb_b",  "type": "Edu-SentenceEmbedding", "position": { "x": 160,  "y": 220 }, "data": { "params": { "model": "multilingual" } } },

    { "id": "cos",    "type": "CosineSimilarity",      "position": { "x": 460,  "y": 120 }, "data": { "params": { "top_k": 1 } } },
    { "id": "print",  "type": "Print",                 "position": { "x": 720,  "y": 120 }, "data": { "params": { "label": "cosine(A, B)" } } }
  ],
  "edges": [
    { "id": "e_trig_a", "source": "start",  "target": "text_a", "sourceHandle": "trigger", "type": "trigger" },
    { "id": "e_trig_b", "source": "start",  "target": "text_b", "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e_ta_ea",  "source": "text_a", "target": "emb_a", "sourceHandle": "text",      "targetHandle": "text" },
    { "id": "e_tb_eb",  "source": "text_b", "target": "emb_b", "sourceHandle": "text",      "targetHandle": "text" },

    { "id": "e_ea_cos", "source": "emb_a",  "target": "cos",   "sourceHandle": "embedding", "targetHandle": "queries" },
    { "id": "e_eb_cos", "source": "emb_b",  "target": "cos",   "sourceHandle": "embedding", "targetHandle": "keys" },

    { "id": "e_cos_pr", "source": "cos",    "target": "print", "sourceHandle": "similarity", "targetHandle": "value" }
  ]
}
