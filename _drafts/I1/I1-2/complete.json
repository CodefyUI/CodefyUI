{
  "name": "I1-2 影像與滑動視窗 — 完整答案圖",
  "description": "對應教材 I1-2。載入一張 224x224 RGB 圖，用同一個『滑動視窗』算子套四種 kernel（模糊 / 邊緣 / 銳化 / 垂直邊緣）各跑一次、並排顯示，看『同一個算子、換 9 個數字就換功能』。RGB 視作一起做（每通道同 kernel，padding=0 → 224 變 222）。下方另接一條檢視支線：Split 把圖拆成 R/G/B 三張各別顯示。",
  "nodes": [
    { "id": "start",       "type": "Start",             "position": { "x": -380, "y": 280 }, "data": { "params": {} } },
    { "id": "img",         "type": "ImageReader",       "position": { "x": -140, "y": 280 }, "data": { "params": { "path": "sample.png", "mode": "RGB", "resize": 0 } } },

    { "id": "win_blur",    "type": "Edu-SlidingWindow2D", "position": { "x": 160, "y": -120 }, "data": { "params": { "preset": "Blur3x3", "padding": 0 } } },
    { "id": "viz_blur",    "type": "Visualize",         "position": { "x": 440, "y": -120 }, "data": { "params": { "title": "Blur", "plot_type": "image" } } },

    { "id": "win_edge",    "type": "Edu-SlidingWindow2D", "position": { "x": 160, "y": 60 },   "data": { "params": { "preset": "EdgeDetection3x3", "padding": 0 } } },
    { "id": "viz_edge",    "type": "Visualize",         "position": { "x": 440, "y": 60 },   "data": { "params": { "title": "Edge", "plot_type": "image" } } },

    { "id": "win_sharpen", "type": "Edu-SlidingWindow2D", "position": { "x": 160, "y": 240 },  "data": { "params": { "preset": "Sharpen3x3", "padding": 0 } } },
    { "id": "viz_sharpen", "type": "Visualize",         "position": { "x": 440, "y": 240 },  "data": { "params": { "title": "Sharpen", "plot_type": "image" } } },

    { "id": "win_vedge",   "type": "Edu-SlidingWindow2D", "position": { "x": 160, "y": 420 },  "data": { "params": { "preset": "VerticalEdge3x3", "padding": 0 } } },
    { "id": "viz_vedge",   "type": "Visualize",         "position": { "x": 440, "y": 420 },  "data": { "params": { "title": "Vertical Edge", "plot_type": "image" } } },

    { "id": "split",       "type": "Split",             "position": { "x": 160, "y": 620 },  "data": { "params": { "chunks": 3, "dim": 0 } } },
    { "id": "viz_r",       "type": "Visualize",         "position": { "x": 440, "y": 580 },  "data": { "params": { "title": "R channel", "plot_type": "image" } } },
    { "id": "viz_g",       "type": "Visualize",         "position": { "x": 440, "y": 700 },  "data": { "params": { "title": "G channel", "plot_type": "image" } } },
    { "id": "viz_b",       "type": "Visualize",         "position": { "x": 440, "y": 820 },  "data": { "params": { "title": "B channel", "plot_type": "image" } } }
  ],
  "edges": [
    { "id": "e_trig",      "source": "start", "target": "img",         "sourceHandle": "trigger", "type": "trigger" },

    { "id": "e_img_blur",  "source": "img",   "target": "win_blur",    "sourceHandle": "tensor",  "targetHandle": "image" },
    { "id": "e_img_edge",  "source": "img",   "target": "win_edge",    "sourceHandle": "tensor",  "targetHandle": "image" },
    { "id": "e_img_shrp",  "source": "img",   "target": "win_sharpen", "sourceHandle": "tensor",  "targetHandle": "image" },
    { "id": "e_img_vedg",  "source": "img",   "target": "win_vedge",   "sourceHandle": "tensor",  "targetHandle": "image" },

    { "id": "e_blur_viz",  "source": "win_blur",    "target": "viz_blur",    "sourceHandle": "image", "targetHandle": "data" },
    { "id": "e_edge_viz",  "source": "win_edge",    "target": "viz_edge",    "sourceHandle": "image", "targetHandle": "data" },
    { "id": "e_shrp_viz",  "source": "win_sharpen", "target": "viz_sharpen", "sourceHandle": "image", "targetHandle": "data" },
    { "id": "e_vedg_viz",  "source": "win_vedge",   "target": "viz_vedge",   "sourceHandle": "image", "targetHandle": "data" },

    { "id": "e_img_split", "source": "img",   "target": "split", "sourceHandle": "tensor",  "targetHandle": "tensor" },
    { "id": "e_split_r",   "source": "split", "target": "viz_r", "sourceHandle": "chunk_0", "targetHandle": "data" },
    { "id": "e_split_g",   "source": "split", "target": "viz_g", "sourceHandle": "chunk_1", "targetHandle": "data" },
    { "id": "e_split_b",   "source": "split", "target": "viz_b", "sourceHandle": "chunk_2", "targetHandle": "data" }
  ]
}
