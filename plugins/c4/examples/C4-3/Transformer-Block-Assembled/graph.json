    { "id": "x",     "type": "TensorInput",            "position": { "x":  -60, "y":   0 }, "data": { "params": { "shape": "1,5,8", "dtype": "float32", "value_mode": "random", "seed": 4 } } },
    { "id": "ln1",   "type": "LayerNorm",              "position": { "x":  240, "y":   0 }, "data": { "params": { "normalized_shape": "8", "eps": 1e-5 } } },
