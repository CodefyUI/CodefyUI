    { "id": "adv",   "type": "TensorInput",      "position": { "x": -100, "y": 180 },  "data": { "params": { "shape": "2", "dtype": "float32", "value_mode": "explicit", "values": [1.0, -1.0] } } },
    { "id": "ppo",   "type": "rl:Edu-PPOClip",   "position": { "x": 280,  "y": 0 },    "data": { "params": { "clip_epsilon": 0.2, "temperature": 1.0 } } },
