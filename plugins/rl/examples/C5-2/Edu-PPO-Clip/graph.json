    { "id": "ln",    "type": "TensorInput",      "position": { "x": -100, "y": -150 }, "data": { "params": { "shape": "2,3", "dtype": "float32", "value_mode": "explicit", "values": [[2, 1, 0], [0, 1, 2]] } } },
    { "id": "lo",    "type": "TensorInput",      "position": { "x": -100, "y": -40 },  "data": { "params": { "shape": "2,3", "dtype": "float32", "value_mode": "explicit", "values": [[1, 1, 1], [1, 1, 1]] } } },
